rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // REGRAS TEMPORÁRIAS PARA DESENVOLVIMENTO DA V4
    // Usar apenas enquanto o site estiver em teste local e sem publicação online.
    // Depois que o admin master estiver validado, trocar por regras finais restritas.

    match /admins/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
